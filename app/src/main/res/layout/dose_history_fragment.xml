<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:padding="20dp"
    tools:context=".ui.history.DoseHistoryFragment">

    <!-- Page Title -->
    <TextView
        android:id="@+id/tvDoseHistoryTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Dose History"
        android:textColor="#1E1E1E"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Page Subtitle -->
    <TextView
        android:id="@+id/tvDoseHistorySubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="View your previous medication doses"
        android:textColor="#6C757D"
        android:textSize="15sp"
        app:layout_constraintTop_toBottomOf="@id/tvDoseHistoryTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Summary Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardDoseSummary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/tvDoseHistorySubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="18dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTotalDosesLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Doses"
                    android:textColor="#6C757D"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvTotalDoses"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0"
                    android:textColor="#2D6A4F"
                    android:textSize="28sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvDoseSummaryIcon"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:gravity="center"
                android:text="💊"
                android:textSize="30sp"
                android:background="#E9F5EF" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Section Title -->
    <TextView
        android:id="@+id/tvRecentHistory"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="Recent History"
        android:textColor="#1E1E1E"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/cardDoseSummary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Dose History List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDoseHistory"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvRecentHistory"
        app:layout_constraintBottom_toTopOf="@id/btnClearHistory"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_dose_history" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/tvEmptyDoseHistory"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="No dose history available yet"
        android:textColor="#888888"
        android:textSize="16sp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/rvDoseHistory"
        app:layout_constraintBottom_toBottomOf="@id/rvDoseHistory"
        app:layout_constraintStart_toStartOf="@id/rvDoseHistory"
        app:layout_constraintEnd_toEndOf="@id/rvDoseHistory" />

    <!-- Clear History Button -->
    <Button
        android:id="@+id/btnClearHistory"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="Clear History"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#D9534F"
        app:cornerRadius="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>