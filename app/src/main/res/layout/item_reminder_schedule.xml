<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvReminderIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="⏰"
            android:textSize="26sp"
            android:background="#E9F5EF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvReminderMedicineName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medicine Name"
                android:textColor="#1E1E1E"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvReminderDose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Dose amount"
                android:textColor="#6C757D"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvReminderTimeRepeat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Time and repeat"
                android:textColor="#888888"
                android:textSize="13sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvReminderStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enabled"
            android:textColor="#2D6A4F"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="#E9F5EF"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>