<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/welcomeFragment">
    <fragment
        android:id="@+id/todayMedicationsFragment"
        android:name="com.example.remedi.ui.medication.TodayMedicationsFragment"
        android:label="Today's Medications"
        tools:layout="@layout/today_medications_fragment" />

    <fragment
        android:id="@+id/welcomeFragment"
        android:name="com.example.remedi.ui.registration.WelcomeFragment"
        android:label="Welcome"
        tools:layout="@layout/welcome_fragment">

        <action
            android:id="@+id/action_welcomeFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.remedi.ui.registration.LoginFragment"
        android:label="Login"
        tools:layout="@layout/login_fragment">

        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />

        <action
            android:id="@+id/action_loginFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.remedi.ui.registration.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/register_fragment">

        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment" />

        <action
            android:id="@+id/action_registerFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.remedi.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/dashboard_fragment">

        <action
            android:id="@+id/action_dashboardFragment_to_medicationListFragment"
            app:destination="@id/medicationListFragment" />

        <action
            android:id="@+id/action_dashboardFragment_to_addEditMedicationFragment"
            app:destination="@id/addEditMedicationFragment" />

        <action
            android:id="@+id/action_dashboardFragment_to_reminderScheduleFragment"
            app:destination="@id/reminderScheduleFragment" />

        <action
            android:id="@+id/action_dashboardFragment_to_doseHistoryFragment"
            app:destination="@id/doseHistoryFragment" />

        <action
            android:id="@+id/action_dashboardFragment_to_profileSettingsFragment"
            app:destination="@id/profileSettingsFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_todayMedicationsFragment"
            app:destination="@id/todayMedicationsFragment" />    </fragment>

    <fragment
        android:id="@+id/medicationListFragment"
        android:name="com.example.remedi.ui.medication.MedicationListFragment"
        android:label="Medication List"
        tools:layout="@layout/medication_list_fragment">

        <action
            android:id="@+id/action_medicationListFragment_to_addEditMedicationFragment"
            app:destination="@id/addEditMedicationFragment" />

        <action
            android:id="@+id/action_medicationListFragment_to_reminderScheduleFragment"
            app:destination="@id/reminderScheduleFragment" />

        <action
            android:id="@+id/action_medicationListFragment_to_doseHistoryFragment"
            app:destination="@id/doseHistoryFragment" />
    </fragment>

    <fragment
        android:id="@+id/addEditMedicationFragment"
        android:name="com.example.remedi.ui.medication.AddEditMedicationFragment"
        android:label="Add/Edit Medication"
        tools:layout="@layout/add_edit_medication_fragment">

        <argument
            android:name="medicationId"
            app:argType="long"
            android:defaultValue="-1L" />

        <action
            android:id="@+id/action_addEditMedicationFragment_to_medicationListFragment"
            app:destination="@id/medicationListFragment" />

        <action
            android:id="@+id/action_addEditMedicationFragment_to_reminderScheduleFragment"
            app:destination="@id/reminderScheduleFragment" />

    </fragment>

    <fragment
        android:id="@+id/reminderScheduleFragment"
        android:name="com.example.remedi.ui.reminderschedule.ReminderScheduleFragment"
        android:label="Reminder Schedule"
        tools:layout="@layout/reminder_schedule_fragment">

        <action
            android:id="@+id/action_reminderScheduleFragment_to_medicationListFragment"
            app:destination="@id/medicationListFragment" />

        <action
            android:id="@+id/action_reminderScheduleFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment" />
    </fragment>

    <fragment
        android:id="@+id/doseHistoryFragment"
        android:name="com.example.remedi.ui.history.DoseHistoryFragment"
        android:label="Dose History"
        tools:layout="@layout/dose_history_fragment">

        <action
            android:id="@+id/action_doseHistoryFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment" />

        <action
            android:id="@+id/action_doseHistoryFragment_to_medicationListFragment"
            app:destination="@id/medicationListFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileSettingsFragment"
        android:name="com.example.remedi.ui.profile.ProfileSettingsFragment"
        android:label="Profile Settings"
        tools:layout="@layout/profile_settings_fragment">

        <action
            android:id="@+id/action_profileSettingsFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment" />

        <action
            android:id="@+id/action_profileSettingsFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/welcomeFragment"
            app:popUpToInclusive="true" />
    </fragment>

</navigation>